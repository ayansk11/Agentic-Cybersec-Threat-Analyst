# LLM Provider: "ollama" or "groq"
LLM_PROVIDER=ollama

# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=hf.co/fdtn-ai/Foundation-Sec-8B-Reasoning-Q4_K_M-GGUF

# Groq settings (optional fallback)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# AlienVault OTX (free API key from https://otx.alienvault.com)
OTX_API_KEY=

# NVD API (optional, increases rate limit from 5 to 50 req/30s)
NVD_API_KEY=

# CISA KEV
CISA_KEV_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json

# MITRE ATT&CK STIX data URL
ATTACK_STIX_URL=https://raw.githubusercontent.com/mitre-attack/attack-stix-data/master/enterprise-attack/enterprise-attack.json

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# Authentication (empty = auth disabled)
API_KEY=

# JWT Authentication (empty = JWT auth disabled, backward compatible)
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# OAuth2 - Google (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/oauth/google/callback

# OAuth2 - GitHub (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/oauth/github/callback

# Frontend URL (for OAuth redirect back to SPA)
FRONTEND_URL=http://localhost:5173

# Initial admin seed (optional, auto-creates first admin on startup)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# CORS (comma-separated allowed origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# Logging
LOG_LEVEL=INFO

# Rate limiting
RATE_LIMIT_ANALYZE=5/minute
RATE_LIMIT_FEED=30/minute

# Caching TTLs (seconds)
CACHE_TTL_CVE=3600
CACHE_TTL_FEED=900

# SMTP Email (empty SMTP_HOST = disabled, tokens logged to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@threatanalyst.local
SMTP_FROM_NAME=ThreatAnalyst
SMTP_USE_TLS=true

# Webhooks (empty = disabled)
WEBHOOK_URL=
WEBHOOK_SEVERITY_THRESHOLD=HIGH
